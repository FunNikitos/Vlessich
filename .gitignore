# -----------------------------------------------------------------------------
# Secrets / env — NEVER commit
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
!*/.env.example
*.enc.dec
terraform.tfvars
!terraform.tfvars.enc
*.tfstate
*.tfstate.*
.terraform/
.terraform.lock.hcl

# Ansible secrets / inventory — only *.example variants are tracked.
ansible/inventory/hosts.yml
ansible/group_vars/all.yml
ansible/group_vars/vpn_nodes/vault.yml
!ansible/inventory/hosts.example.yml
!ansible/group_vars/all.yml.example
!ansible/group_vars/vpn_nodes/vault.yml.example

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
.env.venv/
.mypy_cache/
.pytest_cache/
.ruff_cache/
.coverage
htmlcov/
dist/
build/
*.egg-info/

# -----------------------------------------------------------------------------
# Node
# -----------------------------------------------------------------------------
node_modules/
.vite/
.next/
.cache/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# -----------------------------------------------------------------------------
# Frontend builds
# -----------------------------------------------------------------------------
webapp/dist/
admin/dist/

# -----------------------------------------------------------------------------
# Editors / OS
# -----------------------------------------------------------------------------
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp
*.swo

# -----------------------------------------------------------------------------
# Docker / runtime data
# -----------------------------------------------------------------------------
*.pid
pgdata/
redisdata/

# -----------------------------------------------------------------------------
# Misc
# -----------------------------------------------------------------------------
Dialog.txt
*.bak

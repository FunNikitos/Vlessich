BOT_ENV=dev
BOT_LOG_LEVEL=INFO
BOT_TOKEN=123456:replace_me
BOT_API_BASE_URL=http://api:8000
BOT_API_INTERNAL_SECRET=replace_with_openssl_rand_hex_32
BOT_REDIS_URL=redis://redis:6379/0
BOT_WEBAPP_URL=
BOT_SUPPORT_USERNAME=vlessich_support
# Stage 10: aiohttp endpoint for api broadcaster HMAC pushes.
BOT_INTERNAL_NOTIFY_ENABLED=true
BOT_INTERNAL_NOTIFY_HOST=0.0.0.0
BOT_INTERNAL_NOTIFY_PORT=8081
BOT_INTERNAL_NOTIFY_PATH=/internal/notify/mtproto_rotated
# Stage 11: Billing / Telegram Stars. BOT_BILLING_ENABLED gates the
# /buy menu in the bot UI. Keep BOT_INTERNAL_NOTIFY_ENABLED=true so
# the refund endpoint on :8081 stays reachable for admin refunds
# regardless of billing master flag state.
BOT_BILLING_ENABLED=false
BOT_INTERNAL_REFUND_PATH=/internal/refund/star_payment
# Stage 12: Smart-routing. BOT_SMART_ROUTING_ENABLED gates /config and
# the «📥 Получить конфиг» main-menu button. BOT_SUB_WORKER_BASE_URL
# is the public sub-Worker URL used to format download links the user
# sees after switching profile.
BOT_SMART_ROUTING_ENABLED=false
# BOT_SUB_WORKER_BASE_URL=https://sub.example.com
# Webhook (опционально). Если задано — режим webhook вместо polling.
# BOT_WEBHOOK_URL=https://api.example.com/telegram/webhook
# BOT_WEBHOOK_SECRET=replace_me

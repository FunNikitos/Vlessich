API_ENV=dev
API_LOG_LEVEL=INFO
API_DATABASE_URL=postgresql+asyncpg://vlessich:vlessich@db:5432/vlessich
API_REDIS_URL=redis://redis:6379/1
API_INTERNAL_SECRET=replace_with_openssl_rand_hex_32
API_SECRETBOX_KEY=replace_with_openssl_rand_hex_32
API_PUBLIC_BASE_URL=http://localhost:8000
API_CORS_ORIGINS=["http://localhost:5173","http://localhost:5174"]
API_REMNAWAVE_MODE=mock
API_REMNAWAVE_URL=http://remnawave:3000
# API_REMNAWAVE_TOKEN=required_when_mode_http
API_ADMIN_JWT_SECRET=replace_with_openssl_rand_hex_32
API_ADMIN_JWT_TTL_SEC=3600
API_ADMIN_BCRYPT_COST=12
# Active prober (Stage 5). Defaults are safe for dev.
API_PROBE_INTERVAL_SEC=60
API_PROBE_TIMEOUT_SEC=5
API_PROBE_PORT=443
API_PROBE_BURN_THRESHOLD=3
API_PROBE_RECOVER_THRESHOLD=5
# Observability (Stage 6). Prober metrics port is exposed inside compose.
API_PROBE_METRICS_PORT=9101
# Residential RU probing (Stage 7). Empty = edge-only prober (default).
# Any HTTP response through this proxy counts as reachable (RU blocking
# is TCP/DNS-level). RU results are telemetry-only, they do NOT flip
# nodes.status — only the edge backend drives BURN/RECOVER.
# API_RU_PROXY_URL=
API_RU_PROBE_TIMEOUT_SEC=8
# MTProto seed (Stage 8). Empty = seed skipped (dev).
# Generate: openssl rand -hex 16   (32 hex chars, NO 'ee' prefix).
# API_MTG_SHARED_SECRET_HEX=
API_MTG_SHARED_CLOAK=www.microsoft.com
# Per-user MTProto (Stage 9). Disabled by default; scope='user' in
# /internal/mtproto/issue returns 501 per_user_disabled. Flip to true
# once you actually ran pool_size mtg containers on the port range
# (see ansible/roles/mtg or docker-compose.dev.yml `per-user-mtg` profile).
API_MTG_PER_USER_ENABLED=false
API_MTG_PER_USER_POOL_SIZE=16
API_MTG_PER_USER_PORT_BASE=8443
# Stage 10: shared MTProto auto-rotation cron + rebroadcast pipeline.
# Both master flags ship disabled; flip per-env after smoke-testing
# broadcaster in staging (see docs/plan-stage-10.md rollout).
API_MTG_AUTO_ROTATION_ENABLED=false
API_MTG_SHARED_ROTATION_DAYS=30
API_MTG_ROTATOR_INTERVAL_SEC=3600
API_MTG_BROADCAST_ENABLED=false
API_MTG_BROADCAST_COOLDOWN_SEC=3600
API_MTG_BROADCAST_IDEMPOTENCY_TTL_SEC=86400
API_MTG_BROADCAST_RL_GLOBAL_PER_SEC=30
API_MTG_BROADCAST_RL_PER_CHAT_SEC=1
API_MTG_BROADCAST_STREAM_MAXLEN=10000
API_MTG_BROADCAST_BOT_NOTIFY_URL=http://bot:8081/internal/notify/mtproto_rotated
# Stage 11: Billing / Telegram Stars. Master flag off by default;
# flip on once you've smoke-tested pre_checkout + successful_payment
# in staging. API_BILLING_REFUND_BOT_NOTIFY_URL must point at the bot
# notify_server (:8081) refund endpoint for admin refunds to work.
API_BILLING_ENABLED=false
API_BILLING_PLAN_TTL_PENDING_SEC=3600
API_BILLING_REFUND_BOT_NOTIFY_URL=http://bot:8081/internal/refund/star_payment
# Stage 12: Smart-routing + RU-lists + AdBlock. All flags off by default;
# flip API_SMART_ROUTING_ENABLED to expose routing in sub payload and
# /internal/smart_routing/config, API_RULESET_PULLER_ENABLED to run the
# ruleset_puller worker (antifilter + v2fly geosite + custom YAML).
API_SMART_ROUTING_ENABLED=false
API_RULESET_PULLER_ENABLED=false
API_RULESET_PULL_INTERVAL_SEC=21600
API_RULESET_PULLER_METRICS_PORT=9104
API_RULESET_HTTP_TIMEOUT_SEC=30
API_RULESET_STALE_AFTER_SEC=86400
# Cloudflare Turnstile (admin captcha). Empty = disabled (dev mode).
# API_TURNSTILE_SECRET=
# API_BOT_TOKEN=123:for_initData_validation

# Vlessich — общие переменные для всех хостов.
#
# СКОПИРУЙ как group_vars/all.yml перед первым запуском и заполни обязательные поля.
# Не коммить group_vars/all.yml (см. .gitignore) — только этот .example.

# -----------------------------------------------------------------------------
# SSH публичные ключи администраторов.
#
# ⚠️ КРИТИЧНО: если оставить пустым, после выполнения роли fwknop (single-packet
#    authorization) и перевода SSH на нестандартный порт — SSH станет недоступен
#    на этой ноде без fwknop-клиента. Всегда клади сюда ключ, от которого ты
#    сможешь войти потом.
#
# Формат: одна строка = один pubkey (как в ~/.ssh/authorized_keys).
# -----------------------------------------------------------------------------
ssh_pubkeys:
  # - "ssh-ed25519 AAAAC3Nza... admin@laptop"
  # - "ssh-ed25519 AAAAC3Nza... backup@nas"

# Timezone для всех хостов.
system_timezone: "Europe/Helsinki"

# Адрес control-plane (api + bot) — куда Promtail шлёт логи, node_exporter
# — метрики. Stage 0: ещё не поднят, можно оставить как есть.
control_plane_host: "api.example.com"

{
	email {{ admin_email }}
	auto_https disable_redirects
	servers {
		protocols h1 h2 h3
	}
	log {
		output file /var/log/caddy/access.log {
			roll_size 100MiB
			roll_keep 7
		}
		format json
		level INFO
	}
}

http://{{ public_hostname }} {
	redir https://{host}{uri} permanent
}

https://{{ public_hostname }} {
	root * /var/www/finnish-cloud-services
	file_server
	encode zstd gzip

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		Content-Security-Policy "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self' data:; connect-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=()"
		-Server
	}

	handle /healthz {
		respond "ok" 200
	}

	@hidden path /.git/* /.env* /wp-admin/* /admin/*
	respond @hidden 404
}

# Reality fallback target
https://127.0.0.1:8443 {
	tls internal
	root * /var/www/finnish-cloud-services
	file_server
	header -Server
}

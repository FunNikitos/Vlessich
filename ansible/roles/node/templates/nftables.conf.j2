#!/usr/sbin/nft -f
# =============================================================================
# Vlessich — nftables ruleset (managed by Ansible)
# =============================================================================

flush ruleset

table inet filter {

    # Набор сканеров (Censys/Shodan/GreyNoise/BinaryEdge) — BLOCK
    set scanners4 {
        type ipv4_addr
        flags interval
        elements = {
{% for cidr in nft_scanner_cidrs %}
            {{ cidr }}{{ "," if not loop.last else "" }}
{% endfor %}
        }
    }

    # Блок-лист abuse-ов (fail2ban наполняет)
    set banned4 {
        type ipv4_addr
        timeout 24h
        flags timeout
    }

    chain input {
        type filter hook input priority 0; policy drop;

        # Established / related
        ct state established,related accept
        ct state invalid drop

        # Loopback
        iif lo accept

        # ICMP (разумно ограниченный)
        ip protocol icmp icmp type { echo-request, destination-unreachable, time-exceeded, parameter-problem } limit rate 10/second accept
        ip6 nexthdr icmpv6 accept

        # Drop scanners/banned
        ip saddr @scanners4 drop
        ip saddr @banned4 drop

        # SSH — только после fwknop SPA (порт открывается динамически)
        # (Если fwknop выключен, раскомментировать:)
        # tcp dport {{ ssh_port_new }} accept

        # Разрешённые TCP-порты
{% for port in nft_allowed_tcp_ports %}
{% if port != ssh_port_new %}
        tcp dport {{ port }} accept
{% endif %}
{% endfor %}

        # Разрешённые UDP-порты
{% for port in nft_allowed_udp_ports %}
        udp dport {{ port }} accept
{% endfor %}

        # Rate-limit SYN flood protection
        tcp flags & (fin|syn|rst|ack) == syn limit rate 100/second burst 200 packets accept

        # Всё остальное — RST (отдаём сканерам как «закрыто», а не DROP-тишина)
        # Это ломает сигнатуру «нестандартного порта для VPN»
        meta nfproto ipv4 tcp dport != 0 reject with tcp reset
        counter drop
    }

    chain forward {
        type filter hook forward priority 0; policy drop;
    }

    chain output {
        type filter hook output priority 0; policy accept;
    }
}

# Counter set — для Prometheus метрик через nft-exporter
table inet counters {
    counter blocked_scanners {}
    counter allowed_443_tcp  {}
    counter allowed_443_udp  {}
}

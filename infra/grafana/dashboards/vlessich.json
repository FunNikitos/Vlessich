  "description": "Vlessich observability — HTTP, admin login, prober, subscriptions.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "reqps" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "options": { "legend": { "displayMode": "table", "placement": "right" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (path_template) (rate(vlessich_http_request_duration_seconds_count[1m]))",
          "legendFormat": "{{path_template}}",
          "refId": "A"
        }
      ],
      "title": "HTTP RPS by route",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "s" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.95, sum by (le, path_template) (rate(vlessich_http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p95 {{path_template}}",
          "refId": "A"
        }
      ],
      "title": "HTTP p95 latency by route",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "id": 3,
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (result) (rate(vlessich_admin_login_total[5m]))",
          "legendFormat": "{{result}}",
          "refId": "A"
        }
      ],
      "title": "Admin login outcomes (rate, 5m)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "percentunit" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "id": 4,
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(rate(vlessich_probe_total{ok=\"true\",source=\"edge\"}[5m])) / clamp_min(sum(rate(vlessich_probe_total{source=\"edge\"}[5m])), 1)",
          "legendFormat": "ok ratio (edge)",
          "refId": "A"
        }
      ],
      "title": "Probe success ratio — edge (5m)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "id": 5,
      "options": {},
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "vlessich_node_state == 1",
          "instant": true,
          "legendFormat": "{{hostname}} ({{status}})",
          "refId": "A"
        }
      ],
      "title": "Node states (current)",
      "type": "table"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "id": 6,
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (event) (rate(vlessich_subscription_events_total[5m]))",
          "legendFormat": "{{event}}",
          "refId": "A"
        }
      ],
      "title": "Subscription events (rate, 5m)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "RU residential probes are telemetry-only (do not flip BURN). Divergence edge vs ru ≈ regional DPI / blocking.",
      "fieldConfig": { "defaults": { "unit": "percentunit" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 24 },
      "id": 7,
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (source) (rate(vlessich_probe_total{ok=\"true\"}[5m])) / clamp_min(sum by (source) (rate(vlessich_probe_total[5m])), 1)",
          "legendFormat": "{{source}}",
          "refId": "A"
        }
      ],
      "title": "Probe success ratio — edge vs ru (5m)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "MTProto (mtg) scrape target up/down. Stage 8.",
      "fieldConfig": { "defaults": { "unit": "short", "max": 1, "min": 0 }, "overrides": [] },
      "gridPos": { "h": 4, "w": 12, "x": 0, "y": 32 },
      "id": 8,
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "up{job=\"vlessich-mtg\"}",
          "legendFormat": "mtg up",
          "refId": "A"
        }
      ],
      "title": "MTProto (mtg) up",
      "type": "stat"
    }
  ],
